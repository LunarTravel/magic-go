# ============================================================
# magic-service 环境变量配置模板
# ============================================================
# 使用方法：
#   1. 复制此文件为 .env：cp .env.example .env
#   2. 在 .env 中填入你的真实值（.env 已被 .gitignore 忽略，不会提交）
#   3. configs/config.yaml 中的 ${VAR:-默认值} 占位符会读取这里的值
#
# 优先级：已存在的环境变量 > .env 文件
# 生产环境（K8s/Docker）直接通过环境注入即可，无需 .env
# ============================================================

# ---------- 服务 ----------
APP_ENV=local                      # local | dev | staging | production
SERVER_PORT=9501
SERVER_MODE=debug                  # debug | release | test
SERVER_BASE_PATH=
SERVER_PPROF_ENABLED=true

# ---------- 日志 ----------
LOG_LEVEL=info                     # debug | info | warn | error
LOG_FORMAT=json                    # json | text

# ---------- MySQL ----------
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=magic
MYSQL_USERNAME=root
MYSQL_PASSWORD=                    # 填入数据库密码
MYSQL_CHARSET=utf8mb4

# ---------- Redis ----------
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=                    # 填入 Redis 密码
REDIS_DB=0
